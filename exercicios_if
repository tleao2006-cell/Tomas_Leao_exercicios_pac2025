# EXERCÍCIO LOOP
pares = 0
impares = 0

for i in range(10):
    num = int(input(f"Introduz o  número: "))
    if num % 2 == 0:
        pares += 1
    else:
        impares += 1

print(f"Pares: {pares}")
print(f"Ímpares: {impares}")