segundos = int(input("Digite os segundos: "))

if segundos >= 0:
    horas = segundos // 3600
    minutos = (segundos % 3600) // 60
    segundos_rest = segundos % 60
    print(f"{horas} horas, {minutos} minutos e {segundos_rest} segundos")
else:
    print("Número de segundos inválido, os numeros não podem ser negativo")


