# EXERCÍCIO 8
notas = []
for i in range(10):
    nota = float(input(f"Introduz a nota do aluno {i+1}: "))
    notas.append(nota)

media = sum(notas) / len(notas)
acima_ou_igual = sum(1 for nota in notas if nota >= media)

print(f"Média da turma: {media:.2f}")
print(f"Alunos com nota igual ou acima da média: {acima_ou_igual}")


