print("\n" + "=" * 50)
print("Exercício 5: Criando extraidos.txt")
print("=" * 50)

linhas = conteudo.strip().split('\n')
with open("extraidos.txt", "w", encoding="utf-8") as f:
    for linha in linhas:
        nome_match = re.search(r'Nome:\s([^,]+)', linha)
        email_match = re.search(r'Email:\s([\w\.-]+@[\w\.-]+\.\w+)', linha)
        telefone_match = re.search(r'Telemóvel:\s(\b\d{9}\b|\b\d{3}-\d{3}-\d{3}\b|\b\d{3}\s\d{3}\s\d{3}\b)', linha)
        
        if nome_match and email_match and telefone_match:
            nome = nome_match.group(1)
            email = email_match.group(1)
            telefone = telefone_match.group(1)
            f.write(f"{nome} | {email} | {telefone}\n")
            print(f"{nome} | {email} | {telefone}")


