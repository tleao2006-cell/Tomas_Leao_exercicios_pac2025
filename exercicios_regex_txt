print("\n" + "=" * 50)
print("Exercício 12: Criando resumo.txt")
print("=" * 50)

linhas_registos = registos.strip().split('\n')
with open("resumo.txt", "w", encoding="utf-8") as f:
    for linha in linhas_registos:
        nome_match = re.search(r'Nome:\s([^|]+)', linha)
        nif_match = re.search(r'NIF:\s(\d{9})', linha)
        data_match = re.search(r'Data:\s(\d{2}/\d{2}/\d{4})', linha)
        codigo_match = re.search(r'Código Postal:\s(\d{4}-\d{3})', linha)
        site_match = re.search(r'Site:\shttps?://(?:www\.)?([\w\.-]+\.\w+)', linha)
        
        if nome_match and nif_match and data_match and codigo_match and site_match:
            nome = nome_match.group(1).strip()
            nif = nif_match.group(1)
            data = data_match.group(1)
            codigo = codigo_match.group(1)
            site = site_match.group(1)
            f.write(f"{nome} | {nif} | {data} | {codigo} | {site}\n")
            print(f"{nome} | {nif} | {data} | {codigo} | {site}")


