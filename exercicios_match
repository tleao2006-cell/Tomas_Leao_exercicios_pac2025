# EXERCÍCIO 8
operacao = input("Operação (soma/subtrai/multiplica/divide): ")
num1 = float(input("Número 1: "))
num2 = float(input("Número 2: "))

match operacao:
    case "soma":
        print(num1 + num2)
    case "subtrai":
        print(num1 - num2)
    case "multiplica":
        print(num1 * num2)
    case "divide":
        print(num1 / num2 if num2 != 0 else "Erro: divisão por zero")
    case _:
        print("Operação inválida")

# EXERCÍCIO 9
requisicao = {
