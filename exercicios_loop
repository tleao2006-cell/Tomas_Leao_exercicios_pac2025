def exercicio18():
    def is_perfeito(n):
        soma_divisores = 0
        for i in range(1, n):
            if n % i == 0:
                soma_divisores += i
        return soma_divisores == n
    
    limite = int(input("Digite um número para verificar números perfeitos até ele: "))
    perfeitos = []
    
    for i in range(2, limite + 1):
        if is_perfeito(i):
            perfeitos.append(i)
    
    print(f"Números perfeitos até {limite}: {perfeitos}")
    print(f"Total encontrado: {len(perfeitos)}")

