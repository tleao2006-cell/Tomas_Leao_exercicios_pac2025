# EXERCÍCIO Teste Final 1
def teste_final_1():
    def is_primo(n):
        if n <= 1:
            return False
        for i in range(2, int(n**0.5) + 1):
            if n % i == 0:
                return False
        return True
    
    def contar_divisores(n):
        count = 0
        for i in range(1, n + 1):
            if n % i == 0:
                count += 1
        return count
    
    def is_perfeito(n):
        soma = 0
        for i in range(1, n):
            if n % i == 0:
                soma += i
        return soma == n
    
    def calculadora():
        while True:
            print("\n--- Calculadora ---")
            print("1. Soma")
            print("2. Subtração")
            print("3. Multiplicação")
            print("4. Divisão")
            print("5. Tabuada")
            print("6. Voltar")
            
            op = input("Escolha uma opção: ")
            
            if op == '6':
                break
            
            if op in ['1', '2', '3', '4']:
                a = float(input("Digite o primeiro número: "))
                b = float(input("Digite o segundo número: "))
                
                if op == '1':
                    print(f"{a} + {b} = {a + b}")
                elif op == '2':
                    print(f"{a} - {b} = {a - b}")
                elif op == '3':
                    print(f"{a} * {b} = {a * b}")
                elif op == '4':
                    if b != 0:
                        print(f"{a} / {b} = {a / b}")
                    else:
                        print("Erro: Divisão por zero!")
            
            elif op == '5':
                max_tabuada = int(input("Digite o máximo para a tabuada (1-1000): "))
                if 1 <= max_tabuada <= 1000:
                    for i in range(1, max_tabuada + 1):
                        print(f"\n--- Tabuada do {i} ---")
                        for j in range(1, 11):
                            print(f"{i} x {j} = {i * j}")
                        if i % 20 == 0:
                            continuar = input("Pressione Enter para continuar ou 's' para sair: ")
                            if continuar.lower() == 's':
                                break
                else:
                    print("Valor fora do intervalo permitido!")
    
    # Programa principal
    while True:
        print("\n--- MENU PRINCIPAL ---")
        print("1. Analisar números")
        print("2. Calculadora")
        print("3. Sair")
        
        opcao = input("Escolha uma opção: ")
        
        if opcao == '1':
            num = int(input("Digite um valor entre 1 e 30000: "))
            if 1 <= num <= 30000:
                for i in range(num, 0, -1):
                    print(f"\n--- Analisando {i} ---")
                    print(f"É primo: {'Sim' if is_primo(i) else 'Não'}")
                    print(f"Quantidade de divisores: {contar_divisores(i)}")
                    print(f"É perfeito: {'Sim' if is_perfeito(i) else 'Não'}")
                    
                    if (num - i + 1) % 10 == 0 and i > 1:
                        continuar = input("Pressione Enter para continuar ou 's' para parar: ")
                        if continuar.lower() == 's':
                            break
            else:
                print("Valor fora do intervalo permitido!")
        
        elif opcao == '2':
            calculadora()
        
        elif opcao == '3':
            print("Programa encerrado!")
            break

teste_final_1()
# EXERCÍCIO Teste Final 2
def teste_final_2():
    clientes = []
    num_cliente = 1
    
    def calcular_desconto(compra):
        if 100 <= compra <= 200:
            return compra * 0.05
        elif 200 < compra < 500:
            return compra * 0.10
        elif compra >= 500:
            return compra * 0.15
        else:
            return 0
    
    def inserir_cliente():
        nonlocal num_cliente
        print(f"\n--- Inserir Cliente (Nº {num_cliente}) ---")
        
        nome = input("Nome: ")
        while len(nome) < 3:
            print("Nome deve ter pelo menos 3 caracteres!")
            nome = input("Nome: ")
        
        morada = input("Morada: ")
        while len(morada) < 5:
            print("Morada deve ter pelo menos 5 caracteres!")
            morada = input("Morada: ")
        
        telefone = input("Telefone: ")
        while not telefone.isdigit() or len(telefone) != 9:
            print("Telefone deve ter 9 dígitos!")
            telefone = input("Telefone: ")
        
        nif = input("NIF: ")
        while not nif.isdigit() or len(nif) != 9:
            print("NIF deve ter 9 dígitos!")
            nif = input("NIF: ")
        
        compra = float(input("Valor da compra: "))
        while compra < 0:
            print("Valor da compra não pode ser negativo!")
            compra = float(input("Valor da compra: "))
        
        desconto = calcular_desconto(compra)
        divfin = compra - desconto
        
        cliente = {
            'numcli': num_cliente,
            'nome': nome,
            'morada': morada,
            'telefone': telefone,
            'nif': nif,
            'compra': compra,
            'desconto': desconto,
            'divfin': divfin
        }
        
        clientes.append(cliente)
        num_cliente += 1
        print("Cliente inserido com sucesso!")
    
    def listar_clientes():
        if not clientes:
            print("Nenhum cliente cadastrado!")
            return
        
        for i, cliente in enumerate(clientes):
            print(f"\n--- Cliente {i+1} de {len(clientes)} ---")
            print(f"Nº Cliente: {cliente['numcli']}")
            print(f"Nome: {cliente['nome']}")
            print(f"Morada: {cliente['morada']}")
            print(f"Telefone: {cliente['telefone']}")
            print(f"NIF: {cliente['nif']}")
            print(f"Compra: €{cliente['compra']:.2f}")
            print(f"Desconto: €{cliente['desconto']:.2f}")
            print(f"Divida Final: €{cliente['divfin']:.2f}")
            
            if (i + 1) < len(clientes):
                input("Pressione Enter para ver próximo cliente...")
    
    def buscar_cliente():
        num = int(input("Digite o número do cliente: "))
        encontrado = False
        
        for cliente in clientes:
            if cliente['numcli'] == num:
                print(f"\n--- Cliente Encontrado ---")
                print(f"Nº Cliente: {cliente['numcli']}")
                print(f"Nome: {cliente['nome']}")
                print(f"Morada: {cliente['morada']}")
                print(f"Telefone: {cliente['telefone']}")
                print(f"NIF: {cliente['nif']}")
                print(f"Compra: €{cliente['compra']:.2f}")
                print(f"Desconto: €{cliente['desconto']:.2f}")
                print(f"Divida Final: €{cliente['divfin']:.2f}")
                encontrado = True
                break
        
        if not encontrado:
            print("Cliente não encontrado!")
    
    # Programa principal
    while True:
        print("\n--- BASE DE DADOS DE CLIENTES ---")
        print("1. Inserir Cliente")
        print("2. Listar Clientes")
        print("3. Buscar Cliente por Número")
        print("4. Sair")
        
        opcao = input("Escolha uma opção: ")
        
        if opcao == '1':
            inserir_cliente()
        elif opcao == '2':
            listar_clientes()
        elif opcao == '3':
            buscar_cliente()
        elif opcao == '4':
            print("Programa encerrado!")
            break
        else:
            print("Opção inválida!")

